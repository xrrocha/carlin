{:paths ["src"]

 ;; Runtime deps — trajectory (spec Q1/§13) COMPLETED at S29: hiccup has now
 ;; LEFT this map. It stayed only because carlin.legacy needed it; carlin's
 ;; own serializer landed at step 3, legacy was retired at S29, and nothing
 ;; under src/ has referenced the library since. It remains a :test dep,
 ;; permanently, as the differential oracle (§12.3).
 ;;
 ;; edamame is the one remaining runtime dep (entered with the cursor
 ;; refactor; §13 vendor-vs-depend still open).
 :deps {org.clojure/clojure {:mvn/version "1.12.1"}
        borkdude/edamame    {:mvn/version "1.4.28"}}

 :aliases
 {;; JVM test classpath + runner. hiccup lives here PERMANENTLY as the
  ;; differential-test oracle (spec §12.3); test.check for property tests
  ;; over the escaper and ->js (the "paranoid file", spec §12.2).
  ;; Run: clojure -X:test  (or -M:test -m cognitect.test-runner)
  :test {:extra-paths ["test" "test-resources"]
         :extra-deps  {hiccup/hiccup          {:mvn/version "2.0.0"}
                       org.clojure/test.check {:mvn/version "1.1.3"}
                       io.github.cognitect-labs/test-runner
                       {:git/tag "v0.5.1" :git/sha "dfb30dd"}} ; verify latest tag/sha
         :main-opts ["-m" "cognitect.test-runner"]
         :exec-fn   cognitect.test-runner.api/test}

  ;; Opt-in evaluation backend (spec Q1): runtime template compilation on
  ;; platforms without eval. Kept as a proper k/v ENTRY so uncommenting
  ;; (removing the #_) restores a valid file.
  #_#_:sci {:extra-deps {org.babashka/sci {:mvn/version "0.10.47"}}}

  ;; The CLJS matrix (spec §12, handoff rev. 23 plan item 1). `deftemplate`
  ;; is the CLJS path and has never run under a CLJS compiler — the sandbox
  ;; it was written in had no toolchain and no route to Maven Central, so
  ;; CLJS support is DESIGNED, not DEMONSTRATED. This alias exists so the
  ;; session that fixes that does not have to invent it first.
  ;;
  ;;   clojure -M:cljs-test -m cljs.main -re node -m carlin.cljs-matrix
  ;;
  ;; Version deliberately unpinned-by-comment rather than guessed: verify
  ;; the current release before the first run.
  :cljs-test {:extra-paths ["test" "test-resources"]
              :extra-deps  {org.clojure/clojurescript {:mvn/version "1.11.132"}}}}}
