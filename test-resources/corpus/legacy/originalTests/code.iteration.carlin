items = [1,2,3]

ul
  each [i item] in (map-indexed vector items)
    a= i
    li{:class (str "item-" i)}= item

ul
  each [i item] in (map-indexed vector items)
    li= item

nums = [1,2,3]
letters = ['a', 'b', 'c']

ul
  each l in letters
    each n in nums
      li #{n}: #{l}