mixin centered [title]
  div.centered{:id (:id attributes)}
    if title
      h1{:class (:class attributes)}= title
    block
    if (:href attributes)
      .footer
        a{:href (:href attributes)} Back

mixin main [title]
  div.stretch
    +(centered title).highlight&attributes attributes
      block

mixin bottom []
  div.bottom{:attributes true}
    block

body
  +(centered Hello World)#First
  +(centered "Section 1")#Second
    p Some important content.
  +(centered "Section 2")#Third.foo{:href "menu.html" :class "bar"}
    p Even more important content.
  +(main "Section 3"){:href "#"}
    p Last content.
  +bottom.foo{:class "bar" :name "end" :id "Last" :data-attr "baz"}
    p Some final words.